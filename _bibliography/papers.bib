@article{fleming2026cholinergic,
  title     = {A cholinergic eligibility trace facilitates amygdala plasticity in flavour avoidance learning},
  author    = {Fleming, Weston and Pauli, Jordan L. and Ishii, Kentaro K. and Trzeciak, Marta and Burke, Cassidy T. and Park, Sekun and Gordon, Adam G. and Zweifel, Larry S. and Palmiter, Richard D. and Stuber, Garret D.},
  journal   = {bioRxiv},
  year      = {2026},
  doi       = {10.64898/2026.07.02.734913},
  html      = {https://www.biorxiv.org/content/10.64898/2026.07.02.734913v1},
  pdf       = {https://www.biorxiv.org/content/10.64898/2026.07.02.734913v1.full.pdf},
  #abbr      = {bioRxiv},
  abstract  = {When an animal consumes a new food and consequently feels ill, it rapidly and robustly learns to avoid this food in the future, a form of learning termed conditioned flavour avoidance (CFA). Here we show that a cholinergic projection from the parabrachial nucleus to the central amygdala bridges the long delay between eating and feeling sick to drive CFA learning.},
  preprint  = {true},
  selected  = {true},
  preview   = {Fleming2026.jpg}
}

@article{simon2025opioid,
  title     = {Opioid-driven disruption of the septum reveals a role for neurotensin-expressing neurons in withdrawal},
  author    = {Simon, Rhiana C and Fleming, Weston and Briones, Brandy A and Trzeciak, Marta and Senthilkumar, Pranav and Ishii, Kentaro K and Hjort, Madelyn M and Martin, Madison M and Hashikawa, Koichi and Sanders, Andrea D and Golden, Sam A and Stuber, Garret S},
  journal   = {Neuron},
  year      = {2025},
  html      = {https://www.sciencedirect.com/science/article/pii/S0896627325003071},
  pdf       = {https://pdf.sciencedirectassets.com/272195/1-s2.0-S0896627324X0015X/1-s2.0-S0896627325003071/main.pdf},
  #abbr      = {Neuron},
  abstract  = {Opioid withdrawal is an intensively aversive experience and often drives relapse. The lateral septum (LS) is a forebrain structure that is important in aversion processing and has been linked to substance use disorders, but which LS cell types contribute to the maladaptive state of withdrawal is unknown. We used single-nucleus RNA sequencing to interrogate cell-type-specific gene expression changes induced by chronic morphine exposure and discovered that morphine globally disrupts LS cell types, but neurotensin-expressing neurons (LS-Nts) are selectively activated by naloxone. Using two-photon calcium imaging and ex vivo electrophysiology, we next demonstrate that LS-Nts neurons receive elevated glutamatergic drive in morphine-dependent mice and remain hyperactivated during withdrawal. Finally, we show that manipulating LS-Nts neurons during opioid withdrawal regulates pain coping and sociability. Together, these results suggest that LS-Nts neurons are a key neural substrate involved in opioid withdrawal and establish the LS as a crucial regulator of adaptive behaviors.},
  selected  = {true},
  preview   = {simons2025_2.jpg}
}

