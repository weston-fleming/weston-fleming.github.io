@article{fleming2026cholinergic,
  title     = {A cholinergic eligibility trace facilitates amygdala plasticity in flavour avoidance learning},
  author    = {Fleming, Weston and Pauli, Jordan L. and Ishii, Kentaro K. and Trzeciak, Marta and Burke, Cassidy T. and Park, Sekun and Gordon, Adam G. and Zweifel, Larry S. and Palmiter, Richard D. and Stuber, Garret D.},
  journal   = {bioRxiv},
  year      = {2026},
  doi       = {10.64898/2026.07.02.734913},
  html      = {https://www.biorxiv.org/content/10.64898/2026.07.02.734913v1},
  pdf       = {https://www.biorxiv.org/content/10.64898/2026.07.02.734913v1.full.pdf},
  abbr      = {bioRxiv},
  abstract  = {When an animal consumes a new food and consequently feels ill, it rapidly and robustly learns to avoid this food in the future, a form of learning termed conditioned flavour avoidance (CFA). Here we show that a cholinergic projection from the parabrachial nucleus to the central amygdala bridges the long delay between eating and feeling sick to drive CFA learning.},
  preprint  = {true},
  selected  = {true}
}

